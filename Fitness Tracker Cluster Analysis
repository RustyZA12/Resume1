        "# Theo Odendaal\n",
        "# Student Number: 45031509\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.cluster import KMeans\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "cluster_size1 = np.random.choice(range(100, 1001, 100))\n",
        "cluster_size2 = np.random.choice(range(100, 1001, 100)) #Generation Code\n",
        "cluster_size3 = np.random.choice(range(100, 1001, 100))\n",
        "\n",
        "stepsActive = np.random.uniform(8000, 12000, cluster_size1) #Active Group, Theo Odendaal\n",
        "sleepActive = np.random.uniform(7, 9, cluster_size1)\n",
        "\n",
        "stepsMactive = np.random.uniform(5000, 8000, cluster_size2) #Moderately Active group\n",
        "sleepMactive = np.random.uniform(6, 7.5, cluster_size2)\n",
        "\n",
        "stepsLactive = np.random.uniform(2000, 5000, cluster_size3) #Least Active Group\n",
        "sleepLactive = np.random.uniform(5, 6.5, cluster_size3)\n",
        "\n",
        "steps = np.concatenate([stepsActive, stepsMactive, stepsLactive])\n",
        "sleep = np.concatenate([sleepActive, sleepMactive, sleepLactive])\n",
        "\n",
        "clusterData = np.column_stack((steps, sleep))\n",
        "\n",
        "plt.scatter(steps, sleep)\n",
        "plt.xlabel(\"Steps per Day\")\n",
        "plt.ylabel(\"Hours Slept per Night\")\n",
        "plt.title(\"Fitness Tracker Data Visualisation\")\n",
        "plt.show()\n",
        "\n",
        "kmeans = KMeans(n_clusters=3, random_state=42) #applying Kmeans\n",
        "kmeans.fit(clusterData) #45031509\n",
        "\n",
        "labels = kmeans.labels_\n",
        "\n",
        "plt.scatter(steps, sleep, c=labels)\n",
        "plt.xlabel(\"Steps per Day\")\n",
        "plt.ylabel(\"Hours Slept per Night\")\n",
        "plt.title(\"KMeans Clustering of Fitness Tracker Data\")\n",
        "plt.show()\n",
        "\n",
        "for i in range(3):\n",
        "    cluster = clusterData[labels == i]\n",
        "    avg_steps = np.mean(cluster[:, 0])\n",
        "    avg_sleep = np.mean(cluster[:, 1])\n",
        "\n",
        "    print(f\"Cluster {i+1}:\")\n",
        "    print(f\"Average Steps: {avg_steps:.2f}\") #Cluster Analysis(Averages)\n",
        "    print(f\"Average Sleep: {avg_sleep:.2f}\") #45031509\n",
        "    print()"
      ]
    }
